# Rust build artifacts
/target
**/*.rs.bk

# Editor/OS noise
.DS_Store
.idea/
.vscode/
.omc/

# Perf artifacts
/parity/*.csv
/parity/summary.md
/parity/tmp/*
!/parity/tmp/.gitkeep
/parity/layered_phase_wiring/*.tsv

# Model parity outputs
#
# KEEP (compact summaries, tracked):
#   parity/model_parity/report.md
#   parity/model_parity/diff_details.tsv
#   parity/model_parity/rust_manifest.tsv
#   parity/model_parity/java/java_manifest.tsv
#   parity/model_parity/phase_gate_latest.md
#
# TEMP (regenerated on each parity run):

# Heavy JSON payloads (java input/layout, rust layout)
/parity/model_parity/java/input/
/parity/model_parity/java/layout/
/parity/model_parity/rust/

# Progress log, phase gate snapshots, and diagnostic outputs
/parity/model_parity/rust_runner_progress.tsv
/parity/model_parity/phase_gate_*.json
/parity/model_parity/drift_summary*.txt
/parity/model_parity/ordering_diff_*.tsv
/parity/model_parity/realworld_*.tsv
/parity/model_parity/realworld_*.md
/parity/model_parity/rust_manifest_realworld_*.tsv

# model_parity_full and other variant dirs — all temp
/parity/model_parity_full/
/parity/model_parity_*/java/input/
/parity/model_parity_*/java/layout/
/parity/model_parity_*/rust/
/parity/model_parity_*/rust_runner_progress.tsv
/parity/model_parity_*/**/*.json
# Preserve java_manifest.tsv in variant dirs
!/parity/model_parity_*/java/
!/parity/model_parity_*/java/java_manifest.tsv

/parity/model_parity_categories/
/parity/test_parity/

# Phase trace outputs
/parity/model_parity/java_trace/
/parity/model_parity/rust_trace/
/parity/model_parity_full/java_trace/
/parity/model_parity_full/rust_trace/

# Python cache
__pycache__/
*.pyc

# Auto Claude data directory
.auto-claude/
