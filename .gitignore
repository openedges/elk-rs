# Rust build artifacts
/target
**/*.rs.bk

# NAPI build artifacts (platform-specific binaries)
*.node

# Editor/OS noise
.DS_Store
.idea/
.vscode/
.omc/
.auto-claude/
/.cache/

# Python cache
__pycache__/
*.pyc

# Perf benchmark outputs
/tests/perf/*.csv
/tests/perf/report.md

# Temp test artifacts
/tests/tmp/*
!/tests/tmp/.gitkeep

# Model parity outputs
#
# KEEP (compact summaries, tracked):
#   tests/model_parity/report.md
#   tests/model_parity/diff_details.tsv
#   tests/model_parity/rust_manifest.tsv
#   tests/model_parity/java/java_manifest.tsv
#   tests/model_parity/phase_gate_latest.md
#
# TEMP (regenerated on each parity run):

# Heavy JSON payloads (java input/layout, rust layout)
/tests/model_parity/java/input/
/tests/model_parity/java/layout/
/tests/model_parity/rust/

# Progress log, phase gate snapshots, and diagnostic outputs
/tests/model_parity/rust_runner_progress.tsv
/tests/model_parity/phase_gate_*.json
/tests/model_parity/drift_summary*.txt
/tests/model_parity/ordering_diff_*.tsv
/tests/model_parity/realworld_*.tsv
/tests/model_parity/realworld_*.md
/tests/model_parity/rust_manifest_realworld_*.tsv

# Layered phase wiring artifacts
/tests/layered_phase_wiring/*.tsv

# Script-generated temp dirs
/tests/test_parity/
/tests/model_parity_categories/

# Phase trace outputs
/tests/model_parity/java_trace/
/tests/model_parity/rust_trace/
/tests/model_parity/manifest.tsv
/tests/phase_trace/

# EJC build cache markers (generated by elk_java_common.sh)
.ejc-build-marker

# model_parity variant dirs — all temp except java_manifest.tsv
/tests/model_parity_*/java/input/
/tests/model_parity_*/java/layout/
/tests/model_parity_*/rust/
/tests/model_parity_*/rust_runner_progress.tsv
/tests/model_parity_*/**/*.json
!/tests/model_parity_*/java/
!/tests/model_parity_*/java/java_manifest.tsv

# Full parity local working dir (generated artifacts)
/tests/model_parity_full/
