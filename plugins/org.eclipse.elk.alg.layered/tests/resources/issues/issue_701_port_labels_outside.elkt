algorithm: layered
direction: right

node reference [size: 80, 60]
nodeProperty reference portConstraints:fixedSide
nodeProperty reference portLabelsPlacement:outside

port west of reference size:10,10 side:west
port east of reference size:10,10 side:east
port north of reference size:10,10 side:north
port south of reference size:10,10 side:south

portLabel west text:west size:20,10
portLabel east text:east size:20,10
portLabel north text:north size:20,10
portLabel south text:south size:20,10

node west_partner [size:30,20]
node east_partner [size:30,20]
node north_partner [size:30,20]
node south_partner [size:30,20]

edge west_in: west_partner -> west
edge east_out: east -> east_partner
edge north_out: north -> north_partner
edge south_in: south_partner -> south
