{
  "name": "elk-rs",
  "version": "0.11.0-ext.1",
  "description": "ELK layout engine in Rust — elkjs-compatible API with WASM and native Node.js addon",
  "license": "EPL-2.0",
  "main": "js/index.js",
  "browser": "js/index.browser.js",
  "types": "typings/elk-api.d.ts",
  "exports": {
    ".": {
      "browser": "./js/index.browser.js",
      "default": "./js/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "js/",
    "dist/wasm/",
    "typings/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "sh build.sh",
    "test": "vitest run",
    "test:parity": "node test/parity/run.mjs",
    "bench": "node bench/bench.mjs --mode synthetic",
    "bench:models": "node bench/bench.mjs --mode models",
    "bench:all": "node bench/bench.mjs --mode models --limit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openedges/elk-rs.git",
    "directory": "plugins/org.eclipse.elk.js"
  },
  "homepage": "https://github.com/openedges/elk-rs",
  "bugs": "https://github.com/openedges/elk-rs/issues",
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "elkjs": "^0.11.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@elk-rs/darwin-arm64": "0.11.0",
    "@elk-rs/darwin-x64": "0.11.0",
    "@elk-rs/linux-x64-gnu": "0.11.0",
    "@elk-rs/linux-x64-musl": "0.11.0",
    "@elk-rs/linux-arm64-gnu": "0.11.0",
    "@elk-rs/win32-x64-msvc": "0.11.0"
  },
  "keywords": [
    "elk",
    "layout",
    "graph",
    "wasm",
    "napi",
    "rust"
  ]
}
